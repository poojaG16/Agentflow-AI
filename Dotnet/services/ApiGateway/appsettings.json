{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/auth-service/{**catch-all}"
        }
      },
      "agent-route": {
        "ClusterId": "agent-cluster",
        "Match": {
          "Path": "/agents-service/{**catch-all}"
        }
      },
      "workflow-route": {
        "ClusterId": "workflow-cluster",
        "Match": {
          "Path": "/workflow-service/{**catch-all}"
        }
      }
    }
  },
  "Clusters": {
    "agent-cluster": {
      "Destinations": {
        "agent-destination": {
          "Address": "https://localhost:5002/"
        }
      }
    },
    "auth-cluster": {
      "Destinations": {
        "auth-destination": {
          "Address": "https://localhost:5003/"
        }
      }
    },
    "workflow-cluster": {
      "Destinations": {
        "workflow-destination": {
          "Address": "https://localhost:5004/"
        }
      }
    }
  }
}